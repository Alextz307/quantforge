# ── Python ──
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
dist/
build/
*.so
*.pyd

# ── Virtual environments ──
.venv/
venv/
env/

# ── C++ build artifacts ──
cpp/build/
*.o
*.a
*.dylib
*.dll
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
compile_commands.json
Makefile.cmake

# ── IDE ──
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
cpp/.cache/

# ── Testing / Linting ──
.mypy_cache/
.pytest_cache/
.ruff_cache/
htmlcov/
.coverage
*.gcda
*.gcno

# ── Benchmark results (tracked selectively) ──
