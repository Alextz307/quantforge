# ── Python ──
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
dist/
build/
*.so
*.pyd

# ── Virtual environments ──
.venv/
venv/
env/

# ── C++ build artifacts ──
cpp/build/
*.o
*.a
*.dylib
*.dll
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
compile_commands.json
Makefile.cmake

# ── IDE ──
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
cpp/.cache/

# ── Testing / Linting ──
.mypy_cache/
.pytest_cache/
.ruff_cache/
htmlcov/
.coverage
*.gcda
*.gcno

# ── Benchmark results (tracked selectively) ──
# runs/ and reports/ are ephemeral per-developer artefacts; baselines/ is
# committed so the thesis has a reproducible anchor.
benchmark_results/runs/*.jsonl
benchmark_results/reports/

# ── Experiment results (tracked selectively) ──
# All per-run outputs are ephemeral. The curated thesis-demo sample
# (committed under experiment_results/thesis_demo/sample/) is the only
# tracked artefact bundle; the runtime subdirs inside thesis_demo/ are
# wiped on every `make thesis-demo` invocation. Note: the top-level
# pattern uses ``experiment_results/*`` (children) rather than
# ``experiment_results/`` (the directory itself) so the negation below
# can re-include thesis_demo/ — git refuses to recurse into a fully
# excluded directory to evaluate later negations.
experiment_results/*
!experiment_results/thesis_demo/
experiment_results/thesis_demo/runs/
experiment_results/thesis_demo/comparisons/
experiment_results/thesis_demo/hpo/
experiment_results/thesis_demo/models/
experiment_results/thesis_demo/holdout_evals/

# ── Secrets / local config ──
.env
*.local

# ── scikit-build-core ──
_skbuild/

# ── Profiling ──
*.profdata
*.profraw

# ── Data cache ──
*.parquet
data_cache/
# Committed offline fixtures (used by `make thesis-demo` and offline tests).
!tests/fixtures/*.parquet

# ── Webapp ──
webapp/data/
webapp/.env
webapp/frontend/node_modules/
webapp/frontend/dist/
webapp/frontend/coverage/
webapp/frontend/src/api/generated/
