benchmark_results/runs/*.jsonl

# ── Secrets / local config ──
.env
*.local

# ── scikit-build-core ──
_skbuild/

# ── Profiling ──
*.profdata
*.profraw

# ── Data cache ──
*.parquet
data_cache/
